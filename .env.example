# Email Configuration
# For development, you can use Ethereal Email (free testing service)
# Get credentials at: https://ethereal.email/

# Core backend configuration
NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://localhost:27017/english-practice
REDIS_URL=redis://localhost:6379

# Speech worker topology
ENABLE_INTERNAL_SPEECH_WORKER=false
SPEECH_WORKER_URL=http://localhost:8001
PRONUNCIATION_WORKER_CONCURRENCY=2
PRONUNCIATION_JOB_TIMEOUT_MS=90000

# Frontend / API CORS
FRONTEND_URL=http://localhost:5173
CLIENT_URL=http://localhost:5173
ADMIN_FRONTEND_URL=http://localhost:5180
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5180,http://localhost:8080

# Option 1: Use Ethereal Email (Recommended for testing)
ETHEREAL_USER=your_ethereal_username
ETHEREAL_PASS=your_ethereal_password

# Option 2: Use your own SMTP server (Gmail, SendGrid, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=English Learning Platform <noreply@englishlearning.com>
SUPPORT_EMAIL=support@cognitospeak.com

# Upload / storage
OBJECT_STORAGE_PROVIDER=s3
OBJECT_STORAGE_BUCKET=english-practice-audio
AWS_S3_REGION=eu-north-1
OBJECT_STORAGE_REGION=eu-north-1
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=
