# Email Configuration
# For development, you can use Ethereal Email (free testing service)
# Get credentials at: https://ethereal.email/

# Option 1: Use Ethereal Email (Recommended for testing)
ETHEREAL_USER=your_ethereal_username
ETHEREAL_PASS=your_ethereal_password

# Option 2: Use your own SMTP server (Gmail, SendGrid, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=English Learning Platform <noreply@englishlearning.com>

# Frontend URL (for welcome email CTA button)
FRONTEND_URL=http://localhost:5173
